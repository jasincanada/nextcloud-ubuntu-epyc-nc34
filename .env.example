# =============================================================================
# Nextcloud 34 Testbed / Ubuntu EPYC — Environment Variables
# Copy to .env and fill in your values. Never commit .env.
# =============================================================================

# --- Nextcloud / PostgreSQL ---
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
POSTGRES_PASSWORD=changeme

NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=changeme

# Server IP or hostname — used for trusted domains and Collabora domain allow-list
NC_DOMAIN=192.168.1.x
NEXTCLOUD_TRUSTED_DOMAINS=localhost 127.0.0.1 192.168.1.x

# --- Collabora ---
COLLABORA_ADMIN_PASSWORD=changeme

# --- AppAPI Docker Socket Proxy ---
APPAPI_DSP_PASSWORD=changeme
